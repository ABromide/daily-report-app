{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://daily-report.local/schemas/public/automation-audit.schema.json",
  "title": "Automation audit record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "run_id",
    "generated_at",
    "status",
    "config_path",
    "date_window",
    "category_counts",
    "dedupe",
    "written_item_ids",
    "article_paths"
  ],
  "properties": {
    "version": { "const": 1 },
    "run_id": { "type": "string", "minLength": 1 },
    "generated_at": { "type": "string", "format": "date-time" },
    "status": { "type": "string", "enum": ["dry-run", "complete", "failed"] },
    "config_path": { "type": "string", "minLength": 1 },
    "date_window": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "max_age_days", "timezone"],
      "properties": {
        "mode": { "type": "string", "enum": ["today_or_current_week"] },
        "max_age_days": { "type": "integer", "minimum": 1, "maximum": 7 },
        "timezone": { "type": "string", "minLength": 1 }
      }
    },
    "category_counts": {
      "type": "object",
      "additionalProperties": { "type": "integer", "minimum": 0 }
    },
    "dedupe": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ledger_path", "checked_keys", "duplicate_candidates", "replacement_candidates"],
      "properties": {
        "ledger_path": { "type": "string", "minLength": 1 },
        "checked_keys": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "duplicate_candidates": { "type": "integer", "minimum": 0 },
        "replacement_candidates": { "type": "integer", "minimum": 0 }
      }
    },
    "written_item_ids": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "article_paths": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^articles/[0-9]{4}/[0-9]{2}/[0-9]{2}/[a-z0-9:_-]+/index\\.html$"
      }
    }
  }
}
