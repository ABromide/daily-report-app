{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://daily-report.local/schemas/public/item.schema.json",
  "title": "Public research signal item",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "item_id",
    "category_id",
    "type",
    "source_id",
    "external_id",
    "title",
    "url",
    "canonical_url",
    "published_at",
    "fetched_at",
    "summary_zh",
    "analysis_zh",
    "analysis_html_path",
    "visual",
    "tags",
    "content_hash"
  ],
  "properties": {
    "item_id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9:_-]{2,127}$" },
    "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9:_-]{2,127}$" },
    "category_id": {
      "type": "string",
      "enum": ["llm-agent", "llm-post-training", "ai-safety"]
    },
    "type": { "type": "string", "enum": ["paper", "blog", "code", "report"] },
    "source_id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]{2,63}$" },
    "source_name": { "type": "string", "minLength": 1 },
    "source_type": { "type": "string", "minLength": 1 },
    "external_id": { "type": "string", "minLength": 1 },
    "title": { "type": "string", "minLength": 1 },
    "url": { "type": "string", "format": "uri" },
    "canonical_url": { "type": "string", "format": "uri" },
    "published_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" },
    "fetched_at": { "type": "string", "format": "date-time" },
    "collected_at": { "type": "string", "format": "date-time" },
    "sort_at": { "type": "string", "format": "date-time" },
    "summary": { "type": "string", "minLength": 1 },
    "summary_zh": { "type": "string", "minLength": 1 },
    "analysis_zh": { "type": "string", "minLength": 1 },
    "analysis_html_path": {
      "type": "string",
      "pattern": "^articles/[0-9]{4}/[0-9]{2}/[0-9]{2}/[a-z0-9:_-]+/index\\.html$"
    },
    "language": { "type": "string", "minLength": 2 },
    "reading_minutes": { "type": "integer", "minimum": 1, "maximum": 120 },
    "tags": {
      "type": "array",
      "items": { "type": "string", "minLength": 1, "maxLength": 64 },
      "uniqueItems": true
    },
    "title_hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "content_hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "fingerprint": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "score": { "type": "integer", "minimum": 0, "maximum": 100 },
    "visual": {
      "type": "object",
      "additionalProperties": false,
      "required": ["question", "approach", "takeaway", "metrics"],
      "properties": {
        "question": { "type": "string", "minLength": 1 },
        "approach": {
          "type": "array",
          "minItems": 2,
          "maxItems": 5,
          "items": { "type": "string", "minLength": 1, "maxLength": 96 }
        },
        "takeaway": { "type": "string", "minLength": 1 },
        "metrics": {
          "type": "array",
          "minItems": 1,
          "maxItems": 4,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["label", "value", "score"],
            "properties": {
              "label": { "type": "string", "minLength": 1, "maxLength": 32 },
              "value": { "type": "string", "minLength": 1, "maxLength": 32 },
              "score": { "type": "integer", "minimum": 0, "maximum": 100 }
            }
          }
        }
      }
    },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["type", "label", "url"],
        "properties": {
          "type": { "type": "string", "enum": ["url"] },
          "label": { "type": "string", "minLength": 1 },
          "url": { "type": "string", "format": "uri" }
        }
      }
    }
  }
}
