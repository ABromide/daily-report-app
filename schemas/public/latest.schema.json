{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://daily-report.local/schemas/public/latest.schema.json",
  "title": "Latest public manifest pointer",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "generated_at", "latest_day", "manifest_path", "manifest_sha256"],
  "properties": {
    "version": { "const": 1 },
    "generated_at": { "type": "string", "format": "date-time" },
    "latest_day": { "type": "string", "format": "date" },
    "manifest_path": {
      "type": "string",
      "pattern": "^manifests/[0-9]{4}/[0-9]{2}/[0-9]{2}/[0-9]{6}Z\\.manifest\\.json$"
    },
    "manifest_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
  }
}
