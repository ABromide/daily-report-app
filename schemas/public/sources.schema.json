{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://daily-report.local/schemas/public/sources.schema.json",
  "title": "Public source index",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "generated_at", "sources"],
  "properties": {
    "version": { "const": 1 },
    "generated_at": { "type": "string", "format": "date-time" },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "name", "kind", "homepage_url", "enabled"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]{2,63}$" },
          "name": { "type": "string", "minLength": 1 },
          "kind": { "type": "string", "enum": ["sample", "rss", "api", "manual"] },
          "homepage_url": { "type": "string", "format": "uri" },
          "enabled": { "type": "boolean" },
          "description": { "type": "string" }
        }
      }
    }
  }
}
