---
import type { Signal } from "../lib/data";
import { formatDateTime, formatPercent } from "../lib/format";
import { defaultLocale, getCopy, type Locale } from "../lib/i18n";

interface Props {
  signals: Signal[];
  locale?: Locale;
}

const { signals, locale = defaultLocale } = Astro.props;
const ui = getCopy(locale);
---

<section class="feed-panel" aria-labelledby="priority-feed-title">
  <div class="section-heading feed-heading">
    <div>
      <p class="eyebrow">{ui.feedEyebrow}</p>
      <h2 id="priority-feed-title">{ui.feedTitle}</h2>
    </div>
    <span class="feed-count">{ui.itemCount(signals.length)}</span>
  </div>

  <div class="feed-list">
    {signals.map((signal, index) => (
      <article class:list={["feed-row", { "is-selected": index === 0 }]}>
        <div class="score-cell">
          <strong>{signal.score}</strong>
          <span>{ui.score}</span>
        </div>

        <div class="feed-body">
          <div class="feed-meta">
            <span>{signal.category}</span>
            <span>{signal.source}</span>
            <time datetime={signal.publishedAt}>{formatDateTime(signal.publishedAt, locale)}</time>
          </div>
          <h3>{signal.title}</h3>
          <p>{signal.summary}</p>
          <div class="label-row">
            {signal.labels.map((label) => (
              <span>{label}</span>
            ))}
          </div>
        </div>

        <div class="confidence-cell">
          <span>{formatPercent(signal.confidence)}</span>
          <small>{ui.confidence}</small>
        </div>
      </article>
    ))}
  </div>
</section>
