---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Daily Report Workstation",
  description = "A dense local-first research workstation for Daily Report App."
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
