---
import type { DashboardData, ViewId } from "../lib/data";
import {
  defaultLocale,
  getCopy,
  getLocalePath,
  getViewPath,
  localeMeta,
  type Locale,
  viewOrder
} from "../lib/i18n";
import { formatDateTime } from "../lib/format";

interface Props {
  activeView: ViewId;
  data: DashboardData;
  locale?: Locale;
  variant?: "sidebar" | "mobile";
}

const { activeView, data, locale = defaultLocale, variant = "sidebar" } = Astro.props;
const ui = getCopy(locale);
const basePath = import.meta.env.BASE_URL;
const normalizedBasePath = basePath.endsWith("/") ? basePath : `${basePath}/`;
const hrefFor = (href: string) => {
  if (href === "/") {
    return normalizedBasePath;
  }
  return `${normalizedBasePath}${href.replace(/^\//, "")}`;
};

const counts: Record<ViewId, number> = {
  feed: data.signals.length,
  sources: data.sources.length,
  runs: data.runs.length,
  reports: data.reports.length
};
const navItems = viewOrder.map((id) => ({
  id,
  href: getViewPath(id, locale),
  label: ui.views[id],
  meta: ui.viewMeta[id](counts[id])
}));
const alternateLocale: Locale = locale === "zh" ? "en" : "zh";
---

{
  variant === "sidebar" ? (
    <aside class="sidebar" aria-label={ui.workspaceViews}>
      <div class="brand-block">
        <p class="eyebrow">{ui.appName}</p>
        <a class="brand-title" href={hrefFor(getViewPath("feed", locale))}>{ui.appTitle}</a>
      </div>

      <nav class="nav-list" aria-label={ui.workspaceViews}>
        {navItems.map((item) => (
          <a class:list={["nav-item", { "is-active": item.id === activeView }]} href={hrefFor(item.href)} aria-current={item.id === activeView ? "page" : undefined}>
            <span>{item.label}</span>
            <small>{item.meta}</small>
          </a>
        ))}
      </nav>

      <div class="language-card" aria-label={ui.switchLanguage}>
        <p class="eyebrow">{ui.language}</p>
        <a href={hrefFor(getLocalePath(alternateLocale, activeView))}>
          {localeMeta[locale].label}
          <span>{localeMeta[alternateLocale].label}</span>
        </a>
      </div>

      <div class="sync-card" aria-label={ui.dataSource}>
        <p class="eyebrow">{ui.dataSource}</p>
        <strong>{data.dataMode === "fixture" ? ui.fixtureManifest : ui.mockFallback}</strong>
        <span>{formatDateTime(data.generatedAt, locale)}</span>
      </div>
    </aside>
  ) : (
    <nav class="mobile-tabs" aria-label={ui.mobileViews}>
      {navItems.map((item) => (
        <a class:list={["mobile-tab", { "is-active": item.id === activeView }]} href={hrefFor(item.href)} aria-current={item.id === activeView ? "page" : undefined}>
          <span>{item.label}</span>
        </a>
      ))}
    </nav>
  )
}
