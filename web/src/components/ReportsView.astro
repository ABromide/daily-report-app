---
import type { ReportRecord } from "../lib/data";
import { formatDate } from "../lib/format";

interface Props {
  reports: ReportRecord[];
}

const { reports } = Astro.props;
---

<section class="reports-panel" aria-labelledby="report-archive-title">
  <div class="section-heading">
    <p class="eyebrow">Artifacts</p>
    <h2 id="report-archive-title">Report Archive</h2>
  </div>

  <div class="report-list">
    {reports.map((report) => (
      <article class="report-row">
        <div class="report-heading">
          <div>
            <strong>{report.title}</strong>
            <small>{formatDate(report.date)} · {report.owner}</small>
          </div>
          <span class:list={["status-pill", `report-${report.status}`]}>{report.status}</span>
        </div>
        <p>{report.summary}</p>
        <div class="report-meta">
          <span>{report.sources} sources</span>
          <span>{report.signals} signals</span>
          <span>{report.sections.join(" / ")}</span>
        </div>
      </article>
    ))}
  </div>
</section>
