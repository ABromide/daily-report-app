---
import type { RunRecord } from "../lib/data";
import { formatDateTime } from "../lib/format";
import { defaultLocale, getCopy, runStatusLabel, type Locale } from "../lib/i18n";

interface Props {
  runs: RunRecord[];
  locale?: Locale;
}

const { runs, locale = defaultLocale } = Astro.props;
const ui = getCopy(locale);
---

<section class="table-panel" aria-labelledby="run-ledger-title">
  <div class="section-heading">
    <p class="eyebrow">{ui.automation}</p>
    <h2 id="run-ledger-title">{ui.runLedger}</h2>
  </div>

  <div class="run-stack">
    {runs.map((run) => (
      <article class="run-row">
        <div class="run-marker" aria-hidden="true" />
        <div class="run-main">
          <div class="run-title">
            <strong>{run.id}</strong>
            <span class:list={["status-pill", `run-${run.status}`]}>{runStatusLabel(run.status, locale)}</span>
          </div>
          <p>{run.agent}</p>
          <dl>
            <div>
              <dt>{ui.started}</dt>
              <dd>{formatDateTime(run.startedAt, locale)}</dd>
            </div>
            <div>
              <dt>{ui.duration}</dt>
              <dd>{run.duration}</dd>
            </div>
            <div>
              <dt>{ui.validated}</dt>
              <dd>{run.signalsValidated}</dd>
            </div>
            <div>
              <dt>{ui.errors}</dt>
              <dd>{run.errors}</dd>
            </div>
          </dl>
        </div>
      </article>
    ))}
  </div>
</section>
