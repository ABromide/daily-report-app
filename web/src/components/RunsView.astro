---
import type { RunRecord } from "../lib/data";
import { formatDateTime } from "../lib/format";

interface Props {
  runs: RunRecord[];
}

const { runs } = Astro.props;
---

<section class="table-panel" aria-labelledby="run-ledger-title">
  <div class="section-heading">
    <p class="eyebrow">Automation</p>
    <h2 id="run-ledger-title">Run Ledger</h2>
  </div>

  <div class="run-stack">
    {runs.map((run) => (
      <article class="run-row">
        <div class="run-marker" aria-hidden="true" />
        <div class="run-main">
          <div class="run-title">
            <strong>{run.id}</strong>
            <span class:list={["status-pill", `run-${run.status}`]}>{run.status}</span>
          </div>
          <p>{run.agent}</p>
          <dl>
            <div>
              <dt>Started</dt>
              <dd>{formatDateTime(run.startedAt)}</dd>
            </div>
            <div>
              <dt>Duration</dt>
              <dd>{run.duration}</dd>
            </div>
            <div>
              <dt>Validated</dt>
              <dd>{run.signalsValidated}</dd>
            </div>
            <div>
              <dt>Errors</dt>
              <dd>{run.errors}</dd>
            </div>
          </dl>
        </div>
      </article>
    ))}
  </div>
</section>
