---
import type { DashboardData, ViewId } from "../lib/data";
import { formatDateTime } from "../lib/format";
import { defaultLocale, getCopy, localizeDashboardData, type Locale } from "../lib/i18n";
import DetailInspector from "./DetailInspector.astro";
import FeedPanel from "./FeedPanel.astro";
import KpiStrip from "./KpiStrip.astro";
import Navigation from "./Navigation.astro";
import ReportsView from "./ReportsView.astro";
import RunsView from "./RunsView.astro";
import SourcesView from "./SourcesView.astro";

interface Props {
  data: DashboardData;
  activeView: ViewId;
  locale?: Locale;
}

const { data: rawData, activeView, locale = defaultLocale } = Astro.props;
const data = localizeDashboardData(rawData, locale);
const ui = getCopy(locale);
const selectedSignal = data.signals[0];
const selectedReport = selectedSignal
  ? data.reports.find((report) => report.id === selectedSignal.reportId)
  : data.reports[0];
---

<div class="workstation-shell">
  <Navigation activeView={activeView} data={data} locale={locale} />

  <main class="main-column">
    <header class="topbar">
      <div>
        <p class="eyebrow">{ui.eyebrow}</p>
        <h1>{ui.workstationTitle}</h1>
        <p>{data.windowLabel}</p>
      </div>
      <div class="topbar-status" aria-label={ui.currentDataStatus}>
        <span>{data.dataMode === "fixture" ? ui.fixtureData : ui.mockFallback}</span>
        <strong>{formatDateTime(data.generatedAt, locale)}</strong>
        <small title={data.dataPath}>{data.dataPath}</small>
      </div>
    </header>

    <KpiStrip metrics={data.metrics} locale={locale} />

    {activeView === "feed" ? <FeedPanel signals={data.signals} locale={locale} /> : null}
    {activeView === "sources" ? <SourcesView sources={data.sources} locale={locale} /> : null}
    {activeView === "runs" ? <RunsView runs={data.runs} locale={locale} /> : null}
    {activeView === "reports" ? <ReportsView reports={data.reports} locale={locale} /> : null}
  </main>

  <DetailInspector signal={selectedSignal} report={selectedReport} locale={locale} />
  <Navigation activeView={activeView} data={data} locale={locale} variant="mobile" />
</div>
