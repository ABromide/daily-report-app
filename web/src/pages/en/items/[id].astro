---
import Layout from "../../../components/Layout.astro";
import ShowcaseDetail from "../../../components/ShowcaseDetail.astro";
import { copy } from "../../../lib/i18n";
import { getShowcaseData } from "../../../lib/showcaseContent";

export function getStaticPaths() {
  const data = getShowcaseData("en");
  return data.documents.map((item) => ({
    params: { id: item.id },
    props: { data, item }
  }));
}

const { data, item } = Astro.props;
---

<Layout title={`${item.title} · Daily Report App`} description={copy.en.layoutDescription} locale="en">
  <ShowcaseDetail data={data} item={item} locale="en" />
</Layout>
